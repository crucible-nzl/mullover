{
    email admin@counsel.day
    acme_ca https://acme-v02.api.letsencrypt.org/directory
}

counsel.day {
    root * /var/www/counsel.day
    encode gzip zstd

    # Block internal-only paths at the edge. Defence-in-depth: even if a
    # build script accidentally puts these files back on disk, the edge
    # will 404 them. Update this list when adding new internal pages.
    @blocked path /scripts /scripts/* /og-image-generator.html /homepage.html /components /components.html
    respond @blocked 404

    # Admin panel + its runtime JS bundle. HTTP Basic Auth.
    # Password hash generated 17 May 2026 via `caddy hash-password`.
    # Rotate quarterly; rotate immediately on any team change.
    @admin path /admin /admin.html /admin-app.js
    basicauth @admin {
        admin@counsel.day $2a$14$gwnD/x2rWxEYu4hoRErSFey3.9SvAwpd9YKC44iXcJbhF3yd0H6si
    }

    # Signed-in app surface · session-cookie auth via Next.js. Every request
    # to these paths is forwarded to /api/auth-check first; 401 → redirect
    # to /signin?next=<original>. The static HTML is then served by Caddy.
    # /invite is intentionally NOT in this list: invitees may follow a link
    # before they have an account, so the preview must be readable without
    # a session. The Accept action 401s server-side and the page JS bounces
    # the user to /signup with a return-to.
    @protected path /account /account.html /billing /billing.html /decisions /decisions.html /decision /decision.html /compose /compose.html /vote-today /vote-today.html /verdict-reveal /verdict-reveal.html
    forward_auth @protected 127.0.0.1:3000 {
        uri /api/auth-check
        copy_headers X-Auth-User-Id
        @auth_fail status 401
        handle_response @auth_fail {
            redir * /signin?next={uri}
        }
    }

    # Dynamic routes · reverse-proxied to the Next.js app (systemd:
    # counsel-day-app, bound to 127.0.0.1:3000). Everything else stays
    # on file_server. Keep this list in sync with the routes Next.js owns.
    @app path /api/* /api
    reverse_proxy @app 127.0.0.1:3000 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Real-IP {remote_host}
        transport http {
            keepalive 30s
        }
    }

    try_files {path} {path}.html
    file_server

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "interest-cohort=(), camera=(), microphone=(), geolocation=()"
        Cross-Origin-Opener-Policy "same-origin"
        # CSP · self-hosted fonts mean we no longer need fonts.googleapis.com
        # (style-src) or fonts.gstatic.com (font-src). Google still appears in
        # script-src/connect-src/frame-src for Analytics + Tag Manager + reCAPTCHA.
        # PostHog (EU region) listed in script-src + connect-src · stays
        # dormant until CD_POSTHOG_KEY is set in posthog.js.
        Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://*.googletagmanager.com https://www.google.com/recaptcha/ https://www.gstatic.com/recaptcha/ https://eu-assets.i.posthog.com; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://www.googletagmanager.com https://*.analytics.google.com https://www.google.com/recaptcha/ https://eu.i.posthog.com https://eu-assets.i.posthog.com; frame-src https://www.googletagmanager.com https://www.google.com/recaptcha/ https://stats.uptimerobot.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    }

    # ---- Cache-Control · long-cache fingerprintable assets, no-cache HTML ----
    # Static asset files: woff2/css/js/png/svg/ico/webp/avif have either
    # content-hashed URLs (Google-pattern fonts) or are stable enough that a
    # year-long cache with `immutable` is safe. Bust by renaming the file.
    @static_assets path *.woff2 *.woff *.css *.js *.png *.jpg *.jpeg *.svg *.ico *.webp *.avif *.gif
    header @static_assets Cache-Control "public, max-age=31536000, immutable"

    # HTML must never be long-cached · this is how new deploys reach users.
    # `no-cache` (NOT `no-store`) means: revalidate every time, but the browser
    # may use a conditional GET. Combined with Caddy's ETag/Last-Modified the
    # response is usually a 304 with no body · cheap.
    @html path *.html /
    header @html Cache-Control "no-cache, must-revalidate"

    # Catch the well-known + xml + txt files (sitemap, robots, security.txt,
    # llms.txt, manifest, feed) · short cache so updates propagate fast.
    @meta_files path *.xml *.txt /.well-known/* /manifest.webmanifest
    header @meta_files Cache-Control "public, max-age=3600"
}

www.counsel.day {
    redir https://counsel.day{uri} permanent
}
