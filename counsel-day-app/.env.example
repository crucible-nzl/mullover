# Counsel.day backend env vars.
# Production values live in /etc/counsel-day-app/env.local on the Hetzner box
# (mode 600, owned by deploy). Local dev: copy this to .env and fill in.

# --- Database ---
# Local dev: point at a local postgres or use the production read-only replica.
# Production: postgresql://counsel_day_app:<password>@127.0.0.1:5432/counsel_day
DATABASE_URL=postgresql://localhost:5432/counsel_day

# --- App ---
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://counsel.day

# --- Email (Brevo) ---
# Get this from app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=

# --- Stripe ---
# Get these from dashboard.stripe.com → Developers → API keys
# Use sk_test_* in dev, sk_live_* in production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Anthropic (Claude API for verdict generation) ---
# Get this from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- reCAPTCHA v3 (signup form spam protection) ---
# Get this from google.com/recaptcha/admin
RECAPTCHA_V3_SITE_KEY=
RECAPTCHA_V3_SECRET_KEY=

# --- Session ---
# Generate with: openssl rand -hex 32
# Rotate quarterly. All sessions invalidated on rotation (users re-login).
SESSION_SIGNING_KEY=
