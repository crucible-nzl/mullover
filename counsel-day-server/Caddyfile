# counsel-day-server/Caddyfile
#
# Caddy reverse proxy config for the Hetzner host. Auto-renews
# Let's Encrypt certificates via the Cloudflare DNS-01 challenge.
# The CLOUDFLARE_DNS_API_TOKEN env var is injected at container start
# from Infisical (see SETUP.md Phase C.7).

{
    email james@counsel.day

    # Use Let's Encrypt production endpoint
    acme_ca https://acme-v02.api.letsencrypt.org/directory

    # Sensible defaults across every site below
    servers {
        protocols h1 h2 h3
        timeouts {
            read_body   30s
            read_header 10s
            write       30s
            idle        2m
        }
    }
}

# ----------------------------------------------------------------------------
# vault.counsel.day · Infisical, the self-hosted secrets manager
# ----------------------------------------------------------------------------
vault.counsel.day {
    tls {
        dns cloudflare {env.CLOUDFLARE_DNS_API_TOKEN}
    }

    # Security headers
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "interest-cohort=(), browsing-topics=(), geolocation=(), microphone=(), camera=()"
        -Server
    }

    # Block well-known scanning probes early
    @blocked path /.env /.git/* /wp-admin/* /wp-login.php /xmlrpc.php /phpmyadmin/* /admin.php
    respond @blocked 444

    # Forward to Infisical's backend container on the internal docker network
    reverse_proxy infisical-backend:8080 {
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}

# ----------------------------------------------------------------------------
