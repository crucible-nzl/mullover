# counsel-day-server/.env.example
#
# Copy this to .env.infisical (NOT committed to git) and fill in the values
# before running:
#   docker compose -f docker-compose.infisical.yml --env-file .env.infisical up -d
#
# Generate the secret values with:
#   AUTH_SECRET=$(openssl rand -base64 32)
#   ENCRYPTION_KEY=$(openssl rand -hex 16)
#   DB_PASS=$(openssl rand -base64 32)
#   REDIS_PASS=$(openssl rand -base64 32)
#
# WARNING: AUTH_SECRET and ENCRYPTION_KEY are baked into the Infisical DB on
# first start. Rotating them later requires a planned migration. Store both
# in your offline password manager as a one-time backup.

# ============================================================================
# Required · Infisical core
# ============================================================================

AUTH_SECRET=
ENCRYPTION_KEY=

# ============================================================================
# Required · Infisical Postgres backend
# ============================================================================

DB_PASS=

# ============================================================================
# Required · Infisical Redis
# ============================================================================

REDIS_PASS=

# ============================================================================
# Required · Site URL
# ============================================================================

SITE_URL=https://vault.counsel.day

# ============================================================================
# Required · SMTP (for password reset emails and MFA email codes)
# Use Brevo SMTP relay · the same vendor handling app transactional email.
# ============================================================================

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=vault@counsel.day
SMTP_FROM_NAME=Counsel.day Vault
