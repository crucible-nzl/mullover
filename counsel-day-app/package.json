{
  "name": "counsel-day-app",
  "version": "0.1.0",
  "private": true,
  "description": "Counsel.day backend · Next.js 15 + Drizzle + Postgres. Self-hosted on Hetzner CAX11 behind Caddy.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "next": "15.5.18",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "drizzle-orm": "0.45.2",
    "postgres": "3.4.5",
    "zod": "3.25.76",
    "@node-rs/argon2": "2.0.2",
    "nanoid": "5.0.9",
    "dotenv": "16.4.7",
    "stripe": "17.5.0",
    "@anthropic-ai/sdk": "0.96.0",
    "@sentry/nextjs": "9.45.0",
    "web-push": "3.6.7",
    "@google-analytics/data": "^4.0.0",
    "otplib": "12.0.1"
  },
  "devDependencies": {
    "typescript": "5.7.2",
    "@types/node": "22.10.1",
    "@types/react": "19.0.1",
    "@types/react-dom": "19.0.2",
    "@types/web-push": "3.6.4",
    "drizzle-kit": "0.31.10",
    "tsx": "4.20.6"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
