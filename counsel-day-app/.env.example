# Counsel.day backend env vars.
# Production values live in /etc/counsel-day-app/env.local on the Hetzner box
# (mode 600, owned by deploy). Local dev: copy this to .env and fill in.

# --- Database ---
# Local dev: point at a local postgres or use the production read-only replica.
# Production: postgresql://counsel_day_app:<password>@127.0.0.1:5432/counsel_day
DATABASE_URL=postgresql://localhost:5432/counsel_day

# --- App ---
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://counsel.day

# --- Email (Brevo) ---
# Get this from app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY=

# --- Stripe ---
# Get these from dashboard.stripe.com → Developers → API keys
# Use sk_test_* in dev, sk_live_* in production
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Anthropic (Claude API for verdict generation) ---
# Get this from console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# --- reCAPTCHA v3 (signup form spam protection) ---
# Get this from google.com/recaptcha/admin
RECAPTCHA_V3_SITE_KEY=
RECAPTCHA_V3_SECRET_KEY=

# --- Session ---
# Sessions are opaque random tokens stored in the `sessions` table; no
# signing key is needed. Previously listed here as SESSION_SIGNING_KEY
# but the code never consumed it. Removed 2026-05-20 per pentest 2.5 / 7.3.

# --- Web Push (VAPID) ---
# Generate once: cd counsel-day-app && node -e "console.log(require('web-push').generateVAPIDKeys())"
# Put PUBLIC and PRIVATE into env.local on the server, set SUBJECT to a mailto: of the operator.
# Without these, push subscriptions fail with "no public key from server".
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@counsel.day

# --- DEV / TESTING ONLY · MUST BE UNSET IN PRODUCTION ---
# FIXME(dev-bypass · re-enable before launch · ticket pending):
# When set to a lowercased email, that account skips:
#   · IP + email rate limits on /api/signin
#   · the magic-link round-trip · signing in without a password creates
#     a session immediately
# It does NOT skip password verification or MFA. Every bypass invocation
# is audit-logged (action='auth.dev_bypass.signin') so abuse is visible.
# To DISABLE: remove this line from /etc/counsel-day-app/env.local and
# `sudo systemctl restart counsel-day-app`.
DEV_BYPASS_AUTH_EMAIL=
